#include <iostream>
#include <string>
#include <locale.h>
#include <cstdlib>
#include <time.h>
using namespace std;
int  x[200000] = { }, L[200000] = { }, R[200000] = { };
int main()
{
	setlocale(LC_ALL, "Portuguese");
	int N, Q, somar;
	// CIN
	cin >> N >> Q;
	for (int i = 0; i < N; i++)
	{
		cin >> x[i];
	}
	for (int i = 0; i < Q; i++)
	{
		cin >> L[i] >> R[i];
	}

	for (int i = 0; i < Q; i++)
	{
		somar = 0;
		for (int j = 0; j < N; j++)
		{
			if (x[j]  >= L[i] && x[j] <= R[i])
			{
				somar++;			
			}
		}
		cout << somar << endl;
	}
	return 0;
}
